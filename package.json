{
  "name": "jarvis",
  "version": "2.0.0",
  "description": "JARVIS - AI Personal Assistant for Windows with voice, automation, and deep system integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --windows"
  },
  "author": {
    "name": "echamo89-wq"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/echamo89-wq/Jarvis"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.jarvis.app",
    "productName": "Jarvis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!promo",
      "!server/node_modules",
      "!server/data/jarvis.db",
      "!.git"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jarvis",
      "runAfterFinish": true
    }
  }
}
