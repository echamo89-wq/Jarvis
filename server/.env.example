PORT=3001

# ⚠️ IMPORTANTE: Genera un JWT_SECRET seguro:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiar_esto_en_produccion_123

# CORS: origenes permitidos separados por coma (sin espacios)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,app://.,file://

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PREMIUM_PRICE_ID=price_...
DATABASE_URL=./data/jarvis.db
SERVER_API_KEY=sk-jarvis-server-...
NODE_ENV=development

# Google OAuth — ve a https://console.cloud.google.com/apis/credentials
# Crea un OAuth 2.0 Client ID (Web application) y agrega:
# Authorized redirect URIs: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Actualizaciones: URL de un JSON con formato {version, title, summary, url, notes[]}
# Puede apuntar a GitHub Releases (raw JSON) o a tu propia web
# Ejemplo: https://raw.githubusercontent.com/YOUR_GITHUB_USERNAME/jarvis/main/server/data/latest-release.json
UPDATE_FEED_URL=

# API Keys para proveedores de IA (opcional, pueden configurarse desde la app)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
